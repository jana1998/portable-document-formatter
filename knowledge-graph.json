  "workflows": [
    {
      "id": "document-loading",
      "name": "Document Loading Sequence",
      "steps": [
        "User clicks Open PDF (Toolbar)",
        "window.electronAPI.openFile() via IPC",
        "Main process shows file dialog",
        "FileService.getFileInfo() returns metadata",
        "Store.setCurrentDocument() updates state",
        "PDFViewer effect triggers",
        "window.electronAPI.readFile() fetches PDF bytes",
        "PDFRenderer.loadDocument(ArrayBuffer) initializes PDF.js",
        "PDFRenderer.getPageCount() updates store",
        "PDFRenderer.renderPage() draws to canvas",
        "Overlay layers mount and render"
      ],
      "involved_nodes": [
        "Toolbar.tsx",
        "ipc-bridge",
        "main.ts",
        "file-service.ts",
        "usePDFStore.ts",
        "PDFViewer.tsx",
        "pdf-renderer.ts"
      ]
    },
    {
      "id": "save-export",
      "name": "Save/Export Sequence",
      "steps": [
        "User clicks Save (Toolbar)",
        "SaveDialog opens",
        "User selects pages (all or range)",
        "Dialog gathers modifications from store",
        "window.electronAPI.saveFile() shows save dialog",
        "(Optional) extractPages() for page selection",
        "window.electronAPI.applyModifications() via IPC",
        "Main process PDFService.applyModificationsToPDF()",
        "If textEdits exist → applyTextEditsToPDF() first",
        "Load modified PDF with pdf-lib",
        "Iterate pages and draw modifications",
        "Save to outputPath",
        "Toast notification shows success"
      ],
      "involved_nodes": [
        "Toolbar.tsx",
        "SaveDialog.tsx",
        "usePDFStore.ts",
        "ipc-bridge",
        "main.ts",
        "pdf-service.ts",
        "pdf-lib",
        "mupdf"
      ]
    },
    {
      "id": "annotation-creation",
      "name": "Annotation Creation",
      "steps": [
        "User selects annotation tool (Toolbar)",
        "Store.setCurrentTool(toolId)",
        "AnnotationLayer receives tool change",
        "User drags on canvas (MouseDown, MouseMove, MouseUp)",
        "annotationService.createAnnotation() generates data",
        "Store.addAnnotation() updates Map",
        "AnnotationLayer re-renders with new annotation",
        "SVG element drawn on overlay"
      ],
      "involved_nodes": [
        "Toolbar.tsx",
        "usePDFStore.ts",
        "AnnotationLayer.tsx",
        "annotation-service.ts"
      ]
    },
    {
      "id": "text-editing",
      "name": "Text Editing (Foxit-style)",
      "steps": [
        "User selects Edit Text tool",
        "TextEditLayer mounts",
        "Fetch structured text via window.electronAPI.getPageStructuredText()",
        "Main process calls mupdf",
        "Returns array of {text, bbox, font}",
        "Render transparent clickable overlays",
        "User clicks text line",
        "Input field appears with original text",
        "User edits, presses Enter or blur",
        "Store.addTextEdit() or updateTextEdit()",
        "Overlay shows white background + new text",
        "On Save: textEdits sent to PDFService.applyTextEditsToPDF()"
      ],
      "involved_nodes": [
        "Toolbar.tsx",
        "usePDFStore.ts",
        "TextEditLayer.tsx",
        "ipc-bridge",
        "main.ts",
        "pdf-service.ts",
        "mupdf"
      ]
    },
    {
      "id": "search-execution",
      "name": "Search Execution",
      "steps": [
        "User enters query in SearchPanel",
        "Presses Enter",
        "Create temporary PDFRenderer",
        "Load document from electronAPI.readFile()",
        "Call renderer.searchText(query)",
        "Iterates all pages",
        "Extracts text content with positions",
        "Regex matches query",
        "Returns SearchResult[]",
        "Store.setSearchResults(results)",
        "SearchHighlightLayer renders yellow rectangles",
        "User navigates results with Next/Previous",
        "Store.setCurrentPage() jumps to match"
      ],
      "involved_nodes": [
        "SearchPanel.tsx",
        "pdf-renderer.ts",
        "usePDFStore.ts",
        "SearchHighlightLayer.tsx",
        "ipc-bridge"
      ]
    }
  ],
